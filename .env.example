# OpenAI
OPENAI_API_KEY=

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App Check (opcional) - Chave de site do reCAPTCHA Enterprise cadastrada em
# Firebase Console > Project Settings > App Check > Apps > seu app web
# (a mesma chave WEB ja usada no login por telefone pode ser reaproveitada aqui).
# Sem essa variavel, o App Check simplesmente nao ativa (nada quebra).
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# Funcionalidades opcionais
NEXT_PUBLIC_VOICE_ENABLED=false

# RAG local/híbrido para melhorar busca de produtos e selecionar exemplos relevantes
NEXT_PUBLIC_RAG_ENABLED=true
RAG_PROVIDER=local

# Autenticação por telefone
# firebase = SMS nativo do Firebase Auth (RecaptchaVerifier)
# api = agente usa o chatbot/API de WhatsApp para enviar e verificar o codigo
# supabase = SMS via Supabase Auth (provedor configurado no painel do Supabase, ex: Twilio)
AUTH_MODE=firebase
# Base URL do chatbot_mobile_mercado, ex: https://chatbot-mobile-mercado.onrender.com
AUTH_API_URL=
AUTH_API_SECRET=

# Supabase (usado só quando AUTH_MODE=supabase, para envio/verificação de SMS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Safrapay (API dedicada: projeto safrapay_mobile_api)
SAFRAPAY_MOBILE_API_URL=https://safrapi--appmobileprod-19505.us-east4.hosted.app/
# Opcional: apenas se este app ainda receber webhooks diretamente.
SAFRAPAY_WEBHOOK_SECRET=

# Web Push (notificações) — gere com: node scripts/generate-vapid.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@seudominio.com.br

# Limite de distância de entrega (false = desativado, apenas calcula)
NEXT_PUBLIC_DELIVERY_LIMIT_ENABLED=false
NEXT_PUBLIC_DELIVERY_LIMIT_KM=10
